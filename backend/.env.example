# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/career_planner

# Default LLM Configuration
# Recommended: StepFun official for non-profile-generation tasks
LLM_BASE_URL=https://api.stepfun.com/v1
LLM_API_KEY=your_stepfun_api_key_here
LLM_MODEL=step-3.5-flash

# Profile generation LLM Configuration
# Recommended: keep profile generation on OpenRouter
PROFILE_LLM_BASE_URL=https://openrouter.ai/api/v1
PROFILE_LLM_API_KEY=your_openrouter_api_key_here
PROFILE_LLM_MODEL=stepfun/step-3.5-flash

# Embedding Configuration
EMBEDDING_BASE_URL=https://api.minimax.chat/v1
EMBEDDING_API_KEY=your_api_key_here
EMBEDDING_MODEL=default-embedding-model

# Application
APP_NAME=Career Planner API
DEBUG=false
